meta {
  name: Create Hospital
  type: http
  seq: 1
}

post {
  url: http://localhost:3000/api/v1/hospitals
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Apollo Hospitals Delhi",
