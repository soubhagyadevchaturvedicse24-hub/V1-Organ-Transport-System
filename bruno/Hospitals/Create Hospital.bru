    "hospitalType": "PRIVATE",
    "nabh": true,
    "transplantCapabilities": ["KIDNEY", "LIVER"],
    "address": {
      "street": "Sarita Vihar, Mathura Road",
      "city": "Delhi",
      "state": "Delhi",
      "pincode": "110076"
    },
    "contact": {
      "phone": "9876543210",
      "email": "contact@apollodelhi.com",
      "website": "https://apollodelhi.com"
    }
  }
}
