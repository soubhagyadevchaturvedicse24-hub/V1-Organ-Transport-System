meta {
  name: Reject Hospital
  type: http
  seq: 5
}

post {
  url: http://localhost:3000/api/v1/hospitals/{{hospitalId}}/reject
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "rejectionReason": "License number does not match government records. Please resubmit with correct documentation."
  }
}
