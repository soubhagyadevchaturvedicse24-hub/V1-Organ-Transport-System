meta {
  name: Create Organ
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/organs
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "donorId": "{{donorId}}",
    "organType": "KIDNEY"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("organId", res.body.data._id);
    bru.setEnvVar("organCode", res.body.data.organId);
  }
}
